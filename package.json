{
  "name": "@ninoslat1/easse",
  "version": "0.0.2",
  "author": "ninoslat1",
  "main": "./dist/easse.js",
  "module": "./dist/easse.mjs",
  "devDependencies": {
    "@types/bun": "latest",
    "jsr": "^0.14.3",
    "mitata": "^1.0.34",
    "tsup": "^8.5.1",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "exports": {
    ".": {
      "import": "./dist/easse.mjs",
      "require": "./dist/easse.js",
      "types": "./dist/easse.d.ts"
    }
  },
  "description": "Lightweight SSE adapters for your backend",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build": "tsup src/easse.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/easse.ts --format cjs,esm --watch --dts"
  },
  "type": "module",
  "types": "./dist/easse.d.ts"
}