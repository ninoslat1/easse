{
  "name": "@ninoslat1/easse",
  "version": "0.0.7",
  "author": "ninoslat1",
  "main": "./dist/easse.js",
  "module": "./dist/easse.mjs",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "elysia": "^1.4.28",
    "express": "^5.2.1",
    "hono": "^4.12.10",
    "jsr": "^0.14.3",
    "mitata": "^1.0.34",
    "tsup": "^8.5.1",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "exports": {
    ".": {
      "import": "./dist/easse.js",
      "require": "./dist/easse.js"
    }
  },
  "description": "Lightweight SSE adapters for your backend",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build": "tsup src/easse.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/easse.ts --format cjs,esm --watch --dts",
    "bun-example": "bun run /src/examples/bun.index.ts",
    "node-example": "node --experimental-strip-types ./src/examples/node.index.ts"
  },
  "type": "module",
  "types": "./dist/easse.d.ts"
}
